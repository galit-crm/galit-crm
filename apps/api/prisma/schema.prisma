generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid())
  name         String
  email    String   @unique
  /// Bcrypt hash; DB column remains "passwordHash" for existing migrations.
  password String   @map("passwordHash")
  role     UserRole @default(SALES)
  status       UserStatus  @default(ACTIVE)
  phone        String?
  department   String?
  // Multi-select service ownership (used for lead routing)
  serviceDepartments String[] @default([])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Basic per-user permissions overrides (stage 1 of permissions system)
  canViewFinance         Boolean @default(false)
  canEditFinance         Boolean @default(false)
  canDeleteCustomers     Boolean @default(false)
  canDeleteLeads         Boolean @default(false)
  canManageUsers         Boolean @default(false)
  canManagePermissions   Boolean @default(false)
  canViewAllRecords      Boolean @default(false)

  ownedLeads       Lead[]    @relation("LeadAssignedUser")
  tasks            Task[]    @relation("TaskOwner")
  reports          Report[]  @relation("ReportCreator")
  reviewedReports  Report[]  @relation("ReportReviewer")
  uploadedDocuments Document[] @relation("DocumentUploader")
  collectedSamples LabSample[] @relation("LabSampleCollector")
  assignedProjects Project[] @relation("ProjectTechnician")
  writtenReports   Project[] @relation("ProjectReportWriter")
  opportunities    Opportunity[]
  workStatus       WorkStatus  @default(OFFLINE)

  // Presence (simple heartbeat-based tracking)
  isOnline         Boolean     @default(false)
  lastSeenAt       DateTime?
  currentWorkMode  WorkMode?
  currentProjectId String?
  currentProject   Project?    @relation("UserCurrentProject", fields: [currentProjectId], references: [id])

  leadActivitiesCreated LeadActivity[]
}

model Project {
  id                    String         @id @default(uuid())
  /// מזהה ייחודי מהמערכת המיובאת (לקישור בין ישויות בייבוא)
  importLegacyId        String?
  projectNumber         String?
  name                  String
  client                String
  status                ProjectStatus  @default(NEW)
  progress              Int            @default(0)
  dueDate               DateTime?
  siteVisitDate         DateTime?
  siteVisitTime         String?
  city                  String?
  address               String?
  service               String?
  serviceCategory       String?
  serviceSubType        String?
  contactName           String?
  contactPhone          String?
  urgency               String?
  fieldContactName      String?
  fieldContactPhone     String?
  requiresReport        Boolean        @default(true)
  requiresSampling      Boolean        @default(false)
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  customerId            String?
  customer              Customer?      @relation(fields: [customerId], references: [id])

  assignedTechnicianId  String?
  assignedTechnician    User?          @relation("ProjectTechnician", fields: [assignedTechnicianId], references: [id])

  assignedReportWriterId String?
  assignedReportWriter   User?         @relation("ProjectReportWriter", fields: [assignedReportWriterId], references: [id])

  tasks                 Task[]
  quotes                Quote[]
  reports               Report[]
  documents             Document[]
  labSamples            LabSample[]

  // Presence: which users selected this as current project
  activeUsers           User[]         @relation("UserCurrentProject")

  leads                 Lead[]

  @@index([importLegacyId])
}

model CustomerClassification {
  id        String   @id @default(uuid())
  code      String   @unique
  labelHe   String
  sortOrder Int      @default(0)
  isPreset  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Customer {
  id          String         @id @default(uuid())
  /// מזהה מהמערכת המיובאת (לקישור בין לידים/דוחות/פרויקטים)
  importLegacyId String?
  name        String
  /// סיווג לקוח: קוד מתוך CustomerClassification (למשל COMPANY / C_...)
  type        String
  contactName String
  phone       String
  email       String
  city        String
  address     String?
  status      String         @default("ACTIVE")
  services    String[]
  notes       String?
  /// שדות מיובאים Followup / מערכת ישנה
  phone2           String?
  phone3           String?
  fax              String?
  website          String?
  companyRegNumber String?
  internalNotes    String?    @db.Text
  balanceLegacy    Decimal?   @db.Decimal(18, 2)
  birthdayLegacy   DateTime?
  cityCodeLegacy   String?
  zipLegacy        String?
  legacyUpdatedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  /// Legacy customer card — general / account
  legacyAccountNumber         String?
  legacySubClassificationCode String?
  salesRepresentative         String?
  functionalLabel             String?
  customerSize                String?
  managementProfile           String?
  countryOrRegion             String?

  /// Legacy card — mailing (פרטי דיוור)
  mailingAddress      String?
  mailingCity         String?
  mailingZip          String?
  mailingPoBox        String?
  mailingInvalidField String?
  allowMail           Boolean?
  allowFax            Boolean?
  allowEmail          Boolean?
  allowSms            Boolean?
  mailingNote         String? @db.Text

  /// Legacy card — notes tab metadata
  registrationDate DateTime?
  registrationNote String?   @db.Text
  lastUpdateDate   DateTime?
  lastUpdateNote   String?   @db.Text
  lastUpdatedBy    String?

  /// Legacy card — financial (single record on customer)
  priceList               String?
  roundedPricing          String?
  employeeCount           String?
  managementCustomerLabel String?
  financialNumber1        String?
  financialNumber2        String?
  financialNumber2Large   String?
  financialNumber3        String?
  financeToken            String?
  financeTokenDate        DateTime?
  financeTokenActive      Boolean?
  financeUnnamed1         String?
  financeUnnamed2         String?
  financeUnnamed3         String?
  financeUnnamed4         String?
  totalPurchases          Decimal? @db.Decimal(18, 2)
  totalSales              Decimal? @db.Decimal(18, 2)
  percentageValue         Decimal? @db.Decimal(18, 4)
  paymentTerms            String?
  creditDays              String?
  creditEnabled           Boolean?
  creditNumber            String?
  creditExpiry            String?

  /// Legacy card — פרטים נוספים
  microwaveModel   String?
  detectorLocation String?
  companyAmount    String?
  feature7         String?
  detailDate1      DateTime?
  detailDate3      DateTime?
  detectorModel    String?
  feature4         String?
  companyWall      String?
  feature8         String?
  detailDate2      DateTime?
  detailDate4      DateTime?

  leads       Lead[]
  quotes      Quote[]
  tasks       Task[]
  reports     Report[]
  projects    Project[]
  opportunities Opportunity[]
  documents   Document[]
  labSamples  LabSample[]
  contacts         CustomerContact[]
  salesOrders      SalesOrder[]
  interactions     CustomerInteraction[]
  referralSources        CustomerReferralSource[]
  customerQuestionnaires CustomerQuestionnaire[]
  customerRelations      CustomerRelation[]
  additionalDataRows     CustomerAdditionalDataRow[]
  externalDataRows       CustomerExternalDataRow[]

  @@index([importLegacyId])
  @@index([name])
  @@index([phone])
}

/// מקור הגעה (טאב מקור הגעה)
model CustomerReferralSource {
  id             String    @id @default(uuid())
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date           DateTime?
  sourceName     String?
  rowOrder       Int       @default(0)
  importLegacyId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([customerId])
}

/// שאלונים (טאב שאלונים)
model CustomerQuestionnaire {
  id                String   @id @default(uuid())
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  questionnaireCode String?
  questionnaireName String?
  rowOrder          Int      @default(0)
  importLegacyId    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([customerId])
}

/// קשרים ללקוחות אחרים (טאב קשרים)
model CustomerRelation {
  id                  String   @id @default(uuid())
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  relatedCustomerName String?
  relationType        String?
  rowOrder            Int      @default(0)
  importLegacyId      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([customerId])
}

/// נתונים נוספים — שורות גנריות
model CustomerAdditionalDataRow {
  id             String    @id @default(uuid())
  customerId     String
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  numberValue    String?
  dValue         String?
  dateValue      DateTime?
  text1          String?
  text2          String?
  rowOrder       Int       @default(0)
  importLegacyId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([customerId])
}

/// נתונים חיצוניים — עמודות A–J
model CustomerExternalDataRow {
  id             String   @id @default(uuid())
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  rowOrder       Int      @default(0)
  colA           String?
  colB           String?
  colC           String?
  colD           String?
  colE           String?
  colF           String?
  colG           String?
  colH           String?
  colI           String?
  colJ           String?
  importLegacyId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([customerId])
}

/// איש קשר (Followup: ISH_KESHER)
model CustomerContact {
  id             String   @id @default(uuid())
  /// מזהה ייחודי בייבוא: לרוב Code_Ish_Kesher או customerCode|contactCode
  importLegacyId String
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  fullName       String
  phone          String   @default("")
  mobile         String   @default("")
  fax            String   @default("")
  email          String   @default("")
  address        String   @default("")
  city           String   @default("")
  zip            String   @default("")
  roleTitle      String?
  department     String?
  isPrimary      Boolean  @default(false)
  isActive       Boolean  @default(true)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  quotes       Quote[]
  salesOrders  SalesOrder[]
  interactions CustomerInteraction[]

  @@unique([customerId, importLegacyId])
  @@index([importLegacyId])
}

/// הזמנה (Followup: ORDERS) — נפרד מ-Quote
model SalesOrder {
  id                  String   @id @default(uuid())
  importLegacyId      String?  @unique
  orderNumber         String?
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id])
  customerContactId   String?
  contact             CustomerContact? @relation(fields: [customerContactId], references: [id])
  quoteId             String?
  quote               Quote?   @relation(fields: [quoteId], references: [id])
  status              String   @default("IMPORTED")
  orderDate           DateTime?
  total               Float    @default(0)
  notes               String?  @db.Text
  internalNotes       String?  @db.Text
  deliverySummary     String?  @db.Text
  paymentTerms        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([customerId])
  @@index([importLegacyId])
}

/// פעילות / התקשרות (Followup: HITKASHRUT)
model CustomerInteraction {
  id                  String   @id @default(uuid())
  importLegacyId      String?  @unique
  customerId          String
  customer            Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerContactId   String?
  contact             CustomerContact? @relation(fields: [customerContactId], references: [id])
  activityType        String?
  status              String?
  subject             String?
  notes               String?  @db.Text
  dueDate             DateTime?
  completedDate       DateTime?
  activityDate        DateTime?
  legacyOwnerName     String?
  location            String?
  priority            String?
  createdAt           DateTime @default(now())

  @@index([customerId])
  @@index([importLegacyId])
}

enum ImportJobStatus {
  UPLOADED
  PREVIEW_READY
  RUNNING
  COMPLETED
  FAILED
}

model ImportJob {
  id           String          @id @default(uuid())
  fileName     String
  mimeType     String?
  fileType     String
  status       ImportJobStatus @default(UPLOADED)
  storedPath   String?
  userId       String?
  previewJson  Json?
  resultJson   Json?
  errorMessage String?         @db.Text
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  errors ImportJobError[]
}

model ImportJobError {
  id        String    @id @default(uuid())
  jobId     String
  job       ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  entity    String
  lineRef   String?
  message   String
  rowData   Json?
  createdAt DateTime  @default(now())

  @@index([jobId])
}

model Lead {
  id             String      @id @default(uuid())
  importLegacyId String?
  // Legacy fields (kept for backwards compatibility with existing UI/API)
  firstName      String
  lastName       String?
  phone          String?
  company        String?
  service        String?
  source         String?
  site           String?
  status         String      @default("NEW")
  stage          LeadStage   @default(NEW)
  assignee       String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  // Spec-aligned fields
  fullName       String?
  email          String?
  city           String?
  address        String?
  utm_source     String?
  utm_medium     String?
  utm_campaign   String?
  utm_content    String?
  utm_term       String?
  serviceType    String?
  followUp1Date  DateTime?
  followUp2Date  DateTime?
  nextFollowUpDate DateTime?
  leadStatus     LeadStatus  @default(NEW)

  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])

  assignedUserId String?
  assignedUser   User?       @relation("LeadAssignedUser", fields: [assignedUserId], references: [id])

  opportunities  Opportunity[]
  quotes         Quote[]
  tasks          Task[]

  projectId      String?
  project        Project?    @relation(fields: [projectId], references: [id])

  activities     LeadActivity[]

  @@index([importLegacyId])
}

model LeadActivity {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String
  message     String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

enum WorkStatus {
  AVAILABLE
  IN_FIELD
  IN_OFFICE
  OFFLINE
}

enum WorkMode {
  OFFICE
  FIELD
}

model Opportunity {
  id                   String     @id @default(uuid())
  customerId           String?
  customer             Customer?  @relation(fields: [customerId], references: [id])
  leadId               String?
  lead                 Lead?      @relation(fields: [leadId], references: [id])
  projectOrServiceName String
  estimatedValue       Float      @default(0)
  pipelineStage        OpportunityStage @default(NEW)
  targetCloseDate      DateTime?
  assignedUserId       String?
  assignedUser         User?      @relation(fields: [assignedUserId], references: [id])
  notes                String?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  quotes               Quote[]
}

/// תבנית HTML להצעות מחיר לפי סוג שירות (מנגנון מודרני — ללא Word)
model QuoteTemplate {
  id              String   @id @default(uuid())
  name            String
  /// התאמה לשדה Quote.service / בחירת שירות בטופס (מחרוזת זהה)
  serviceType     String
  isActive        Boolean  @default(true)
  introHtml       String?  @db.Text
  bodyHtml        String?  @db.Text
  closingHtml     String?  @db.Text
  termsHtml       String?  @db.Text
  /// טקסט עזר למנהלים: רשימת משתני {{...}} (אופציונלי)
  variablesHelp   String?  @db.Text
  /// מערך: { name, quantity, unitPrice }[]
  defaultLineItems Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quotes Quote[]

  @@index([serviceType])
  @@index([isActive])
}

model Quote {
  id          String       @id @default(uuid())
  importLegacyId String?
  quoteNumber String?
  service     String
  description String?
  // Legacy amount (kept); spec uses amountBeforeVat + vatPercent + discount
  amount      Float
  status      QuoteStatus  @default(DRAFT)
  validTo     DateTime
  pdfPath     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customerId  String
  customer    Customer     @relation(fields: [customerId], references: [id])

  customerContactId String?
  customerContact   CustomerContact? @relation(fields: [customerContactId], references: [id])

  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id])

  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id])

  opportunityId           String?
  opportunity             Opportunity? @relation(fields: [opportunityId], references: [id])

  // Spec-aligned quote fields
  validityDate            DateTime?
  amountBeforeVat         Float?     @default(0)
  vatPercent              Float?     @default(17)
  discountType            DiscountType @default(NONE)
  discountValue           Float?     @default(0)
  totalAmount             Float?     @default(0)
  paymentTerms            String?
  notes                   String?
  digitalSignatureStatus  DigitalSignatureStatus @default(NOT_REQUESTED)

  // Automation helpers
  sentAt                  DateTime?
  reminderNextAt          DateTime?
  reminderCount           Int?       @default(0)

  // Origami preparation (no integration yet)
  signedPdfPath           String?
  digitalCertificateMeta  Json?
  signatureRequestedAt    DateTime?
  signedAt                DateTime?

  quoteTemplateId String?
  quoteTemplate   QuoteTemplate? @relation(fields: [quoteTemplateId], references: [id], onDelete: SetNull)
  /// גוף HTML ממוזג לתצוגה מקדימה / PDF עתידי
  contentHtml     String? @db.Text
  /// פריטי שורה שנשמרו מהתבנית/עריכה
  lineItemsJson   Json?

  salesOrders SalesOrder[]

  @@index([importLegacyId])
}

model Task {
  id          String        @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    TaskPriority  @default(MEDIUM)
  status      TaskStatus    @default(OPEN)
  type        TaskType      @default(GENERAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ownerId     String
  owner       User          @relation("TaskOwner", fields: [ownerId], references: [id])

  customerId  String?
  customer    Customer?     @relation(fields: [customerId], references: [id])

  leadId      String?
  lead        Lead?         @relation(fields: [leadId], references: [id])

  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
}

model Report {
  id          String      @id @default(uuid())
  importLegacyId String?
  projectId      String?
  project        Project?    @relation(fields: [projectId], references: [id])

  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])

  title          String
  // Legacy fields kept for backwards compatibility (older seed/UI)
  type           String?
  filtersJson    String?     @default("{}")

  reportType     ReportType   @default(OTHER)
  status         ReportStatus @default(WAITING_DATA)

  createdById    String
  createdBy      User        @relation("ReportCreator", fields: [createdById], references: [id])

  reviewedById   String?
  reviewedBy     User?       @relation("ReportReviewer", fields: [reviewedById], references: [id])

  reportDate     DateTime?
  sentAt         DateTime?
  pdfPath        String?
  version        Int         @default(1)
  internalNotes  String?
  clientNotes    String?

  documents      Document[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([importLegacyId])
}

model Document {
  id            String       @id @default(uuid())
  importLegacyId String?
  name          String
  documentType  DocumentType @default(OTHER)
  filePath      String
  description   String?
  mimeType      String?
  sizeBytes     Int?
  documentDate  DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  projectId     String?
  project       Project?     @relation(fields: [projectId], references: [id])

  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])

  reportId      String?
  report        Report?      @relation(fields: [reportId], references: [id])

  uploadedById  String?
  uploadedBy    User?        @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([importLegacyId])
}

model LabSample {
  id                  String           @id @default(uuid())
  sampleNumber        String
  sampleType          LabSampleType    @default(OTHER)
  sampleStatus        LabSampleStatus  @default(COLLECTED)
  collectedAt         DateTime?
  receivedAt          DateTime?
  analyzedAt          DateTime?
  locationDescription String?
  testType            String?
  method              String?
  resultValue         String?
  resultUnit          String?
  resultStatus        LabResultStatus  @default(PENDING)
  resultFilePath      String?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  projectId           String?
  project             Project?         @relation(fields: [projectId], references: [id])

  customerId          String?
  customer            Customer?        @relation(fields: [customerId], references: [id])

  collectedById       String?
  collectedBy         User?            @relation("LabSampleCollector", fields: [collectedById], references: [id])
}

model SystemSetting {
  key        String   @id
  value      Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

model QuoteItemCatalog {
  id               String   @id @default(uuid())
  itemCode         String   @unique
  name             String
  description      String?
  serviceCategory  String?
  serviceSubType   String?
  basePrice        Float    @default(0)
  billingUnit      String
  vatPercent       Float    @default(17)
  isActive         Boolean  @default(true)
  requiresQuantity Boolean  @default(true)
  requiresSiteVisit Boolean @default(false)
  requiresReport   Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum ReportType {
  RADIATION_REPORT
  ACOUSTIC_REPORT
  AIR_QUALITY_REPORT
  ASBESTOS_REPORT
  RADON_REPORT
  ODOUR_REPORT
  SOIL_REPORT
  LAB_REPORT
  OTHER
}

enum ReportStatus {
  WAITING_DATA
  IN_WRITING
  IN_REVIEW
  SENT
  CLOSED
}

enum DocumentType {
  CONTRACT
  QUOTE
  PLAN
  PHOTO
  REPORT
  LAB_RESULT
  CERTIFICATE
  INVOICE
  OTHER
}

enum LabSampleType {
  AIR
  SURFACE
  WATER
  SOIL
  RADON
  ASBESTOS
  MICROBIOLOGY
  OTHER
}

enum LabSampleStatus {
  COLLECTED
  RECEIVED
  IN_ANALYSIS
  COMPLETED
  REPORTED
}

enum LabResultStatus {
  NORMAL
  ABNORMAL
  PENDING
}

enum UserRole {
  ADMIN
  MANAGER
  SALES
  TECHNICIAN
  EXPERT
  BILLING
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LeadStage {
  NEW
  CONTACTED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadStatus {
  NEW
  CONTACTED
  FU_1
  FU_2
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
  NOT_RELEVANT
}

enum OpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  SIGNED
  EXPIRED
}

enum DiscountType {
  NONE
  CURRENCY
  PERCENT
}

enum DigitalSignatureStatus {
  NOT_REQUESTED
  REQUESTED
  SIGNED
  FAILED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskType {
  SALES_FOLLOWUP
  QUOTE_PREPARATION
  COORDINATION
  FIELD_WORK
  REPORT_WRITING
  REVIEW
  COLLECTION
  GENERAL
}

